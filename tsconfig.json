{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "moduleResolution": "node",
    "jsx": "react",
    "baseUrl": ".",
    "outDir": "./dist"
  },
  "include": ["src/**/*.tsx"],
  "exclude": ["node_modules", "bower_components"]
}
